---
interface Props {
  title: string;
}

const { title } = Astro.props;

function hueFromTitle(s: string): number {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) & 0xffffffff;
  return Math.abs(h) % 360;
}

const bg = `oklch(58% 0.19 ${hueFromTitle(title)})`;
const letter = title.trim()[0]?.toUpperCase() ?? '?';
---

<div class="squircle squircle-shape" style={`--sq-bg:${bg}`} aria-hidden="true">
  {letter}
</div>

<style>
  .squircle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: var(--sq-bg, oklch(58% 0.19 0));
    color: #fff;
    font-weight: 700;
    font-size: calc(100% * 1.4);
    font-family: system-ui, -apple-system, sans-serif;
    user-select: none;
  }
</style>
