---
const navPages = [
  { title: 'About', url: '/about/' },
];
---

<header class="site-header" role="banner">
  <div class="wrapper">
    <a class="site-title" rel="author" href="/">Natpakan K.</a>

    <nav class="site-nav" aria-label="Main navigation">
      <label for="nav-trigger" class="menu-icon" aria-label="Open menu">
        <svg viewBox="0 0 18 15" width="18" height="15" aria-hidden="true">
          <path d="M18,1.484c0,0.82-0.665,1.484-1.484,1.484H1.484C0.665,2.969,0,2.304,0,1.484l0,0C0,0.665,0.665,0,1.484,0 h15.032C17.335,0,18,0.665,18,1.484L18,1.484z M18,7.516C18,8.335,17.335,9,16.516,9H1.484C0.665,9,0,8.335,0,7.516l0,0 c0-0.82,0.665-1.484,1.484-1.484h15.032C17.335,6.031,18,6.696,18,7.516L18,7.516z M18,13.516C18,14.335,17.335,15,16.516,15H1.484 C0.665,15,0,14.335,0,13.516l0,0c0-0.82,0.665-1.483,1.484-1.483h15.032C17.335,12.031,18,12.695,18,13.516L18,13.516z"/>
        </svg>
      </label>
      <input type="checkbox" id="nav-trigger" class="nav-trigger" />

      <div class="trigger">
        <div class="theme-toggle-wrap">
          <input type="checkbox" class="theme-toggle-checkbox" id="theme-chk" />
          <label class="theme-toggle-label" for="theme-chk" aria-label="Toggle dark mode">
            <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="tt-icon tt-sun" width="13" height="13" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7"></path>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="tt-icon tt-moon" width="13" height="13" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
              <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"></path>
            </svg>
            <div class="tt-ball">
              <span class="sr-only">Toggle dark mode</span>
            </div>
          </label>
        </div>

        {navPages.map(p => (
          <a class="page-link" href={p.url}>{p.title}</a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  // Theme toggle (checkbox-based)
  (function () {
    const chk = document.getElementById('theme-chk') as HTMLInputElement | null;
    if (!chk) return;

    function syncCheckbox() {
      chk!.checked = document.documentElement.getAttribute('data-theme') === 'dark';
    }

    syncCheckbox();

    chk.addEventListener('change', () => {
      const next = chk!.checked ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  })();

  // Close burger on scroll
  (function () {
    const navTrigger = document.getElementById('nav-trigger') as HTMLInputElement | null;
    if (!navTrigger) return;
    window.addEventListener('scroll', () => {
      if (navTrigger.checked) navTrigger.checked = false;
    }, { passive: true });
  })();
</script>
