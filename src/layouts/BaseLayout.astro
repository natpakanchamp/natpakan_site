---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  isNotesPage?: boolean;
}

const { title, description = 'Natpakan K.', isNotesPage = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{title} | Natpakan K.</title>

    <!-- Anti-FOUC: apply saved theme before paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          if (!stored) {
            stored = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)
              ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', stored);
          // set bg inline ก่อน CSS โหลด เพื่อไม่ให้ safe area แสดงสีดำ
          document.documentElement.style.backgroundColor = stored === 'dark' ? '#1b1b1b' : '#fdfdfd';
        } catch (e) {}
      })();
    </script>

    <!-- Sarabun font (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Sarabun:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
    />

    <slot name="head" />
  </head>

  <body class={isNotesPage ? 'notes-page' : ''}>
    <Header />

    <main class="page-content" aria-label="Content">
      <div class="wrapper">
        <slot />
      </div>
    </main>

    <Footer />

    <!-- Headroom: hide navbar on scroll down -->
    <script src="/assets/js/headroom.min.js" is:inline></script>
    <script is:inline>
      (function () {
        var header = document.querySelector('.site-header');
        if (!header || !window.Headroom) return;

        var headroom = new Headroom(header, {
          offset: 80,
          tolerance: { up: 5, down: 0 }
        });
        headroom.init();

        // Keep the header pinned & frozen while the font slider is in use:
        // growing the text reflows the page and fires a downward-scroll event
        // that Headroom would otherwise read as intent to hide the navbar.
        var unfreezeTimer = null;
        function holdHeader() {
          if (unfreezeTimer) clearTimeout(unfreezeTimer);
          headroom.pin();
          headroom.freeze();
        }
        function releaseHeader(delay) {
          if (unfreezeTimer) clearTimeout(unfreezeTimer);
          unfreezeTimer = setTimeout(function () { headroom.unfreeze(); }, delay);
        }

        // Freeze only for the duration of a slider interaction (covers the
        // mobile case where the slider sits inside the open burger menu). Every
        // path schedules an unfreeze, so Headroom can never get stuck pinned.
        var slider = document.getElementById('font-size-slider');
        if (slider) {
          slider.addEventListener('input', function () { holdHeader(); releaseHeader(600); });
          slider.addEventListener('pointerdown', holdHeader);
          window.addEventListener('pointerup', function () { releaseHeader(600); });
          window.addEventListener('touchend', function () { releaseHeader(600); });
        }
      })();
    </script>

    <!-- Slider: init all .slider elements on the page -->
    <script src="/assets/js/slider.js" defer></script>
  </body>
</html>
