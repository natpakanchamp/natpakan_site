---
import BaseLayout from './BaseLayout.astro';
import Squircle from '@/components/Squircle.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;

const dateFormat = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

function postUrl(slug: string, categories: string[]): string {
  const m = slug.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
  if (!m) return `/posts/${slug}/`;
  const [, year, month, day, title] = m;
  const cat = categories.includes('notes') ? 'notes' : 'activities';
  return `/${cat}/${year}/${month}/${day}/${title}/`;
}

// filter out notes, sort newest first
const blogPosts = posts
  .filter(p => !p.data.categories?.includes('notes'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function extractImages(body: string): string[] {
  const urls: string[] = [];
  for (const m of body.matchAll(/!\[.*?\]\(([^)\s]+)\)/g)) urls.push(m[1]);
  for (const m of body.matchAll(/<img[^>]+src=["']([^"']+)["']/gi)) urls.push(m[1]);
  return [...new Set(urls)];
}
---

<BaseLayout title="Home">
  <div class="home">
    <slot />

    {blogPosts.length > 0 && (
      <>
        <h2 class="post-list-heading">Posts</h2>
        <ul class="post-list">
          {blogPosts.map(post => {
            const imgs = extractImages(post.body);
            return (
            <li data-images={JSON.stringify(imgs)}>
              <div class="post-cover">
                <Squircle title={post.data.title} />
              </div>
              <div class="post-list-text">
                <span class="post-meta">{dateFormat.format(post.data.date)}</span>
                <h3>
                  <a class="post-link" href={postUrl(post.slug, post.data.categories ?? [])}>
                    {post.data.title}
                  </a>
                </h3>
              </div>
            </li>
            );
          })}
        </ul>
      </>
    )}
  </div>
<script>
  document.querySelectorAll<HTMLLIElement>('.post-list > li[data-images]').forEach(li => {
    const imgs: string[] = JSON.parse(li.dataset.images || '[]');
    if (!imgs.length) return;

    const picked = imgs[Math.floor(Math.random() * imgs.length)];
    const cover = li.querySelector<HTMLElement>('.post-cover');
    const svg = cover?.querySelector('svg');
    if (!cover || !svg) return;

    const img = document.createElement('img');
    img.src = picked;
    img.alt = '';
    img.setAttribute('aria-hidden', 'true');
    img.className = 'squircle-cover';
    img.onerror = () => img.replaceWith(svg); // fallback ถ้า load ไม่ได้
    cover.replaceChild(img, svg);
  });
</script>
</BaseLayout>
