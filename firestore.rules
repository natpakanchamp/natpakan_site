rules_version = '2';

// View-counter rules for the `pageViews` collection.
// - anyone may read counts (to display them)
// - writes are only allowed if they create count=1 or increment by exactly 1,
//   so the endpoint can't be used to write arbitrary data.
service cloud.firestore {
  match /databases/{database}/documents {
    match /pageViews/{slug} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count == 1;

      allow update: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count == resource.data.count + 1;

      allow delete: if false;
    }
  }
}
